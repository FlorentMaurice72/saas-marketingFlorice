# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Required. Generate with: npx auth secret  OR  openssl rand -base64 32
AUTH_SECRET=

# ─── App URL ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000

